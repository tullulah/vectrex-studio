[project]
name = "moving_vectors"
version = "0.1.0"
entry = "src/main.vpy"

[build]
output = "build/moving_vectors.bin"
optimization = 2
debug_symbols = true

[sources]
vpy = ["src/**/*.vpy"]

[resources]
music = ["assets/music/*.vmus"]
sfx = ["assets/sfx/*.vsfx"]
vectors = ["assets/vectors/*.vec"]
